{
  "name": "@bzbj/stillon",
  "type": "module",
  "version": "0.2.0",
  "private": true,
  "description": "Still On — leave your Mac, keep your coding agents",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/bzbj/stillon#readme",
  "bugs": {
    "url": "https://github.com/bzbj/stillon/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "chat",
    "ui",
    "agent",
    "anthropic",
    "remote-access",
    "always-on",
    "bun",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bzbj/stillon.git"
  },
  "bin": {
    "stillon": "./bin/stillon"
  },
  "packageManager": "bun@1.3.5",
  "files": [
    "bin/",
    "src/server/",
    "src/shared/",
    "dist/client/",
    "dist/export-viewer/"
  ],
  "engines": {
    "bun": ">=1.3.5"
  },
  "scripts": {
    "build": "bun run build:client && bun run build:export-viewer",
    "build:client": "bun ./node_modules/vite/bin/vite.js build",
    "build:export-viewer": "bun ./node_modules/vite/bin/vite.js build --config vite.export-viewer.config.ts",
    "prepare:export-viewer-release-assets": "bun run ./scripts/prepare-export-viewer-release-assets.ts",
    "release:verify": "bun run ./scripts/assert-release-version.ts",
    "check": "bun ./node_modules/typescript/bin/tsc --noEmit && bun run build:client && bun run build:export-viewer",
    "audit": "bun audit --audit-level=high",
    "dev": "bun run ./scripts/dev.ts",
    "dev:client": "bun ./node_modules/vite/bin/vite.js --host 127.0.0.1 --port 5174",
    "dev:server": "bun run ./scripts/dev-server.ts --no-open --port 5175",
    "install:dev": "bun install && bun run build && bun install -g .",
    "start": "bun run ./src/server/cli.ts",
    "test": "bun run ./scripts/run-tests.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.207",
    "@anthropic-ai/sdk": "^0.111.0",
    "@legendapp/list": "3.3.2",
    "@pierre/diffs": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-select": "^2.2.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "default-shell": "^2.2.0",
    "file-type": "^22.0.0",
    "openai": "^6.34.0",
    "react-resizable-panels": "^4.7.3",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@babel/core": "^7.29.7",
    "fast-uri": "^3.1.3",
    "hono": "^4.12.29",
    "ip-address": "^10.2.0",
    "picomatch": "^4.0.5",
    "postcss": "^8.5.16",
    "qs": "^6.15.3"
  },
  "optionalDependencies": {
    "@typescript/typescript-win32-arm64": "7.0.2",
    "@typescript/typescript-win32-x64": "7.0.2"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "latest",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "^10.4.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "typescript": "7.0.2",
    "vite": "^8.1.4",
    "zustand": "^5.0.10"
  }
}
